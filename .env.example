# ============================================================
#  LiGHT Grant System — Environment Variables
#  Copy this file to .env and fill in real values.
#  Never commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Local dev: use docker-compose defaults
# Railway: copy the DATABASE_URL from your Postgres plugin
DATABASE_URL=postgresql://light:light@localhost:5432/light_grants

# ── Redis ────────────────────────────────────────────────────
# Local dev: use docker-compose defaults
# Railway: copy the REDIS_URL from your Redis plugin
REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App URLs ─────────────────────────────────────────────────
# Local dev
BASE_URL=http://localhost:3000
API_URL=http://localhost:8000
# Railway production — update after services are deployed:
# BASE_URL=https://your-frontend.up.railway.app
# API_URL=https://your-backend.up.railway.app

ENVIRONMENT=development
DEBUG=false

# ── Cloudflare R2 Object Storage ─────────────────────────────
# Create bucket at dash.cloudflare.com → R2
# Create API token: R2 overview → Manage R2 API Tokens → Create Token (Object Read & Write)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=grantengine

# ── Email / SMTP (Resend) ────────────────────────────────────
# Sign up at resend.com → API Keys → Create API Key
# Use the API key as the SMTP password
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
# Use onboarding@resend.dev on free tier; set your verified domain in production
SMTP_FROM=onboarding@resend.dev
SMTP_PASSWORD=re_your_resend_api_key

# ── Google OAuth (optional) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Slack Notifications (optional) ──────────────────────────
SLACK_WEBHOOK_URL=

# ============================================================
#  Railway Production Checklist
#  Set these in the Railway dashboard per service:
#
#  Backend + Worker + Beat services:
#    DATABASE_URL   → from Railway Postgres plugin
#    REDIS_URL      → from Railway Redis plugin
#    SECRET_KEY     → random 64-char hex
#    OPENAI_API_KEY → your key
#    R2_*           → all four R2 vars above
#    SMTP_*         → all four SMTP vars above
#    BASE_URL       → https://your-frontend.up.railway.app
#    API_URL        → https://your-backend.up.railway.app
#    ENVIRONMENT    → production
#    DEBUG          → false
#
#  Frontend service only (one extra var):
#    NEXT_PUBLIC_API_URL → https://your-backend.up.railway.app
# ============================================================
