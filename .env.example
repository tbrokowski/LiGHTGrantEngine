# ============================================================
#  LiGHT Grant System — Environment Variables
#  Copy this file to .env and fill in real values.
#  Never commit .env to version control.
# ============================================================

# Database
DATABASE_URL=postgresql://light:light@localhost:5432/light_grants

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-long-random-string

# Qwen API (if your cluster requires auth)
QWEN_API_KEY=EMPTY

# Email (SMTP)
SMTP_PASSWORD=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack (optional)
SLACK_WEBHOOK_URL=

# Environment
ENVIRONMENT=development
DEBUG=false
